def alphabeta(depth, node, maximizing, values, alpha, beta):
    # Base case: leaf node
    if depth == 2:
        return values[node]

    if maximizing:
        best = -999
        for i in range(2):
            val = alphabeta(depth + 1, node * 2 + i, False, values, alpha, beta)
            best = max(best, val)
            alpha = max(alpha, best)
            if beta <= alpha:
                break  # Beta cut-off
        return best
    else:
        best = 999
        for i in range(2):
            val = alphabeta(depth + 1, node * 2 + i, True, values, alpha, beta)
            best = min(best, val)
            beta = min(beta, best)
            if beta <= alpha:
                break  # Alpha cut-off
        return best

# Example leaf node values
values = [3, 5, 6, 9]

# Run alpha-beta pruning
result = alphabeta(0, 0, True, values, -999, 999)
print("Result:", result)


