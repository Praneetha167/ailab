graph = {}

# Number of nodes
n = int(input("Enter number of nodes: "))

print("Enter node and its neighbors (space separated):")
print("Example: A B C")

for _ in range(n):
    data = input().split()
    node = data[0]
    neighbors = data[1:]
    graph[node] = neighbors

# Start node input
start_node = input("Enter starting node: ")

# Perform BFS
result = bfs(graph, start_node)

