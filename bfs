from collections import deque

# Function to perform BFS
def bfs(graph, start_node):
    visited = set()
    queue = deque([start_node])
    traversal_order = []

    while queue:
        node = queue.popleft()

        if node not in visited:
            visited.add(node)
            traversal_order.append(node)

            for neighbor in graph[node]:
                if neighbor not in visited:
