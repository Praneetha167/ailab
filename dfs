# Function to perform DFS
def dfs(graph, start_node, visited=None, traversal_order=None):
    if visited is None:
        visited = set()                  # To keep track of visited nodes
    if traversal_order is None:
        traversal_order = []             # List to store traversal result

    visited.add(start_node)
    traversal_order.append(start_node)

    # Visit all unvisited neighbors
    for neighbor in graph[start_node]:
        if neighbor not in visited:
            dfs(graph, neighbor, visited, traversal_order)

    return traversal_order


# Example graph represented as an adjacency list
graph = {
    'A': ['B', 'C'],
    'B': ['D', 'E'],
    'C': ['F'],
    'D': [],
    'E': ['F'],
    'F': []
}

# Perform DFS starting from node 'A'
result = dfs(graph, 'A')
print("Depth-First Traversal:", result)
