    data = input().split()
    node = data[0]
    neighbors = data[1:]
    graph[node] = neighbors

# Start node input
start_node = input("Enter starting node: ")

# Perform DFS
result = dfs(graph, start_node)

print("Depth-First Traversal:", result)
