def hanoi(n, source, dest, aux):
    if n == 1:
        print(f"Move disk 1 from {source} -> {dest}")
        return
    hanoi(n - 1, source, aux, dest)
    print(f"Move disk {n} from {source} -> {dest}")
    hanoi(n - 1, aux, dest, source)

