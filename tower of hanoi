def hanoi(n, source, dest, aux):
    if n == 1:
        print(source, "->", dest)
        return
    hanoi(n - 1, source, aux, dest)
    print(source, "->", dest)
    hanoi(n - 1, aux, dest, source)

# Example usage: move 3 disks from A to C using B as auxiliary
hanoi(3, 'A', 'C', 'B')


