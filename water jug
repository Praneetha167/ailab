def dfs_water_jug(m, n, d):
    visited = set()
    path = []

    def dfs(x, y):
        if (x, y) in visited:
            return False
        visited.add((x, y))
        path.append((x, y))

        if x == d or y == d:
            return True
        
        # Generate all possible next states
        states = [
            (m, y), (x, n), (0, y), (x, 0),
            (x - min(x, n - y), y + min(x, n - y)),  # Pour jug1 -> jug2
            (x + min(y, m - x), y - min(y, m - x))   # Pour jug2 -> jug1
        ]
        
        for state in states:
            if dfs(*state):
                return True
        
        path.pop()
        return False

    if dfs(0, 0):
        return path
    else:
        return None

