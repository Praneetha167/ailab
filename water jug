from collections import deque

# -----------------------
# BFS solution
# -----------------------
def bfs_water_jug(m, n, d):
    visited = set()
    queue = deque()
    parent = {}  # To reconstruct the path

    start = (0, 0)
    queue.append(start)
    visited.add(start)
    parent[start] = None

    while queue:
        x, y = queue.popleft()
        
        if x == d or y == d:
            # Reconstruct path
            path = []
            current = (x, y)
            while current is not None:
                path.append(current)
                current = parent[current]
            return path[::-1]  # Start -> goal
        
        # Generate all possible next states
        states = [
            (m, y),        # Fill jug1
            (x, n),        # Fill jug2
            (0, y),        # Empty jug1
            (x, 0),        # Empty jug2
            (x - min(x, n - y), y + min(x, n - y)),  # Pour jug1 -> jug2
            (x + min(y, m - x), y - min(y, m - x))   # Pour jug2 -> jug1
        ]
        
        for state in states:
            if state not in visited:
                visited.add(state)
                queue.append(state)
                parent[state] = (x, y)
    
    return None  # No solution

